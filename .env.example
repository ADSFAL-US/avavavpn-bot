# ==========================================
# Telegram Bot Configuration
# ==========================================

# Bot Token from @BotFather (required)
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated Telegram user IDs, required)
ADMIN_IDS=123456789

# Database path inside container (default: /app/data/avava_vpn.db)
DATABASE_PATH=/app/data/avava_vpn.db

# ==========================================
# X-Controller Integration (Subscription Panel)
# ==========================================

# X-Controller API URL for subscription management
XCONTROLLER_URL=http://localhost:8080

# X-Controller Admin Credentials (Basic Auth)
XCONTROLLER_USERNAME=admin
XCONTROLLER_PASSWORD=change_me_in_production

# ==========================================
# YooKassa Payment Integration
# ==========================================

# YooKassa Shop ID (from YooKassa merchant account)
YOOKASSA_SHOP_ID=your_shop_id

# YooKassa Secret Key (from YooKassa merchant account)
YOOKASSA_API_KEY=your_secret_key

# Test mode (true for testing, false for production)
YOOKASSA_TEST_MODE=true

# ==========================================
# Bot Settings (optional)
# ==========================================

# Support contact (username or link)
SUPPORT_USERNAME=@support_username

# Default trial period in days
DEFAULT_TRIAL_DAYS=3