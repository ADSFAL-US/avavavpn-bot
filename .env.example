# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated Telegram user IDs)
ADMIN_IDS=123456789

# Database path (default: avava_vpn.db)
DATABASE_PATH=avava_vpn.db

# VPN Configuration
VPN_SERVER_ADDRESS=vpn.avava.local
VPN_PORT=1194
VPN_PROTOCOL=udp