# ==========================================
# Telegram Bot Configuration
# ==========================================

# Bot Token from @BotFather (required)
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated Telegram user IDs, required)
ADMIN_IDS=123456789

# Database path inside container (default: /app/data/avava_vpn.db)
DATABASE_PATH=/app/data/avava_vpn.db

# ==========================================
# X-Controller Integration (optional)
# ==========================================

# X-Controller API URL for subscription management
XCONTROLLER_URL=http://localhost:8080

# X-Controller API Key (if configured in controller)
XCONTROLLER_API_KEY=

# ==========================================
# Bot Settings (optional)
# ==========================================

# Support contact (username or link)
SUPPORT_USERNAME=@support_username

# Default trial period in days
DEFAULT_TRIAL_DAYS=3