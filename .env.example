# Avava VPN Bot Environment Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (get from @BotFather on Telegram)
BOT_TOKEN=your_bot_token_here

# Admin User IDs (Telegram user IDs, comma-separated)
ADMIN_IDS=0

# Database path
DATABASE_PATH=./avava_vpn.db

# VPN Configuration
VPN_SERVER_ADDRESS=vpn.avava.local
VPN_PORT=1194
VPN_PROTOCOL=udp

# X-Controller Integration
XCONTROLLER_URL=http://localhost:8080
XCONTROLLER_API_KEY=your_xcontroller_api_key_here

# Bot Settings
SUPPORT_USERNAME=@support
DEFAULT_TRIAL_DAYS=3

# YooKassa Payment Settings
# Get from https://yookassa.ru/
YOOKASSA_SHOP_ID=your_shop_id_here
YOOKASSA_API_KEY=your_api_key_here
YOOKASSA_TEST_MODE=true
YOOKASSA_WEBHOOK_SECRET=

# Payment return URL
PAYMENT_RETURN_URL=